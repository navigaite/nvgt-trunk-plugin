{
  "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss", "stylelint-config-clean-order"],
  "rules": {
    "at-rule-no-deprecated": null,
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "plugin",
          "reference"
        ]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": ["theme"]
      }
    ]
  }
}
